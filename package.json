{
  "name": "frame",
  "version": "0.1.0",
  "description": "AI-native TypeScript SDK skeleton — reference implementation with hexagonal architecture",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/postgres": {
      "import": {
        "types": "./dist/adapters/postgres.d.ts",
        "default": "./dist/adapters/postgres.js"
      },
      "require": {
        "types": "./dist/adapters/postgres.d.cts",
        "default": "./dist/adapters/postgres.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsup",
    "depcruise": "depcruise src",
    "verify-hooks": "node scripts/verify-hooks.js",
    "check:codegen-drift": "tsx scripts/check-codegen-drift.ts",
    "check": "pnpm lint && pnpm depcruise && pnpm typecheck && pnpm check:codegen-drift && pnpm test:coverage && tsx examples/create-cat.ts && tsx examples/create-cat.with-otel.ts && pnpm verify-hooks",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:reset": "docker compose -f docker/docker-compose.yml down -v && docker compose -f docker/docker-compose.yml up -d && sleep 2 && pnpm db:migrate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:codegen": "kysely-codegen --url postgresql://frame:frame@localhost:54320/frame --out-file src/adapters/db-types.generated.ts",
    "prepare": "husky"
  },
  "keywords": [
    "sdk",
    "skeleton",
    "hexagonal",
    "typescript",
    "ai-native"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@opentelemetry/sdk-logs": "0.215.0",
    "@opentelemetry/sdk-trace-base": "2.7.0",
    "@opentelemetry/sdk-trace-node": "2.7.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "better-sqlite3": "^12.9.0",
    "dependency-cruiser": "^17.3.10",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "kysely-codegen": "^0.20.0",
    "lint-staged": "^16.4.0",
    "testcontainers": "^11.14.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json}": [
      "biome check --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
